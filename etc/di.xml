<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:framework:ObjectManager/etc/config.xsd">

    <virtualType name="NicepayFacade" type="Magento\Payment\Model\Method\Adapter">
        <arguments>
            <argument name="code" xsi:type="const">Nicepay\NicePayment\Gateway\Config\Config::CODE</argument>
            <argument name="formBlockType" xsi:type="string">Magento\Payment\Block\Form</argument>
            <argument name="infoBlockType" xsi:type="string">Nicepay\NicePayment\Block\Info</argument>
            <argument name="valueHandlerPool" xsi:type="object">NicepayValueHandlerPool</argument>
            <argument name="commandPool" xsi:type="object">NicepayCommandPool</argument>
        </arguments>
    </virtualType>

    <type name="Nicepay\NicePayment\Gateway\Config\Config">
        <arguments>
            <argument name="methodCode" xsi:type="const">Nicepay\NicePayment\Gateway\Config\Config::CODE</argument>
        </arguments>
    </type>

    <!-- Command pool -->
    <virtualType name="NicepayCommandPool" type="Magento\Payment\Gateway\Command\CommandPool">
        <arguments>
            <argument name="commands" xsi:type="array">
                <item name="initialize" xsi:type="string">NicepayInitializeCommand</item>
                <item name="refund" xsi:type="string">NicepayRefundCommand</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Initialize command -->
    <virtualType name="NicepayInitializeCommand" type="Magento\Payment\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder" xsi:type="object">NicepayInitializeRequest</argument>
            <argument name="transferFactory" xsi:type="object">
                Nicepay\NicePayment\Gateway\Http\NicepayTransferFactoryInterface
            </argument>
            <argument name="client" xsi:type="object">Nicepay\NicePayment\Gateway\Http\Client\InitializeClient</argument>
        </arguments>
    </virtualType>

    <!-- Refund command -->
    <virtualType name="NicepayRefundCommand" type="Magento\Payment\Gateway\Command\GatewayCommand">
        <arguments>
            <argument name="requestBuilder" xsi:type="object">NicepayRefundRequest</argument>
            <argument name="transferFactory" xsi:type="object">
                Nicepay\NicePayment\Gateway\Http\NicepayTransferFactoryInterface
            </argument>
            <argument name="handler" xsi:type="object">Nicepay\NicePayment\Model\Handler\RefundHandler</argument>
            <argument name="client" xsi:type="object">Nicepay\NicePayment\Gateway\Http\Client\RefundClient</argument>
        </arguments>
    </virtualType>

    <!-- Initialization Request -->
    <virtualType name="NicepayInitializeRequest" type="Magento\Payment\Gateway\Request\BuilderComposite">
        <arguments>
            <argument name="builders" xsi:type="array">
                <item name="transaction" xsi:type="string">Nicepay\NicePayment\Gateway\Request\InitializationRequest</item>
            </argument>
        </arguments>
    </virtualType>

    <!-- Refund Request -->
    <virtualType name="NicepayRefundRequest" type="Magento\Payment\Gateway\Request\BuilderComposite">
        <arguments>
            <argument name="builders" xsi:type="array">
                <item name="transaction" xsi:type="string">Nicepay\NicePayment\Gateway\Request\RefundRequest</item>
            </argument>
        </arguments>
    </virtualType>

    <type name="Nicepay\NicePayment\Gateway\Request\InitializationRequest">
        <arguments>
            <argument name="config" xsi:type="object">Nicepay\NicePayment\Gateway\Config\Config</argument>
        </arguments>
    </type>

    <type name="Magento\Framework\Model\Entity\RepositoryFactory">
        <arguments>
            <argument name="entities" xsi:type="array">
                <item name="Nicepay\NicePayment\Api\Data\PostInterface" xsi:type="string">
                    Nicepay\NicePayment\Api\Data\PostRepositoryInterface
                </item>
            </argument>
        </arguments>
    </type>

    <virtualType name="NicepayValueHandlerPool" type="Magento\Payment\Gateway\Config\ValueHandlerPool">
        <arguments>
            <argument name="handlers" xsi:type="array">
                <item name="default" xsi:type="string">NicepayConfigValueHandler</item>
            </argument>
        </arguments>
    </virtualType>
    <virtualType name="NicepayConfigValueHandler" type="Magento\Payment\Gateway\Config\ConfigValueHandler">
        <arguments>
            <argument name="configInterface" xsi:type="object">Nicepay\NicePayment\Gateway\Config\Config</argument>
        </arguments>
    </virtualType>

    <type name="Nicepay\NicePayment\Block\Info">
        <arguments>
            <argument name="config" xsi:type="object">Nicepay\NicePayment\Gateway\Config\Config</argument>
        </arguments>
    </type>

    <type name="Magento\Quote\Model\Quote\Payment">
        <plugin name="nicepayQuotePayment" type="Nicepay\NicePayment\Plugin\QuotePaymentPlugin"/>
    </type>

    <type name="Magento\Config\Model\Config\Structure\Element\Group">
        <plugin name="nicepayConfigElementGroup" type="Nicepay\NicePayment\Plugin\ConfigElementGroupPlugin"/>
    </type>

    <type name="Nicepay\NicePayment\Logger\Handler">
        <arguments>
            <argument name="filesystem" xsi:type="object">Magento\Framework\Filesystem\Driver\File</argument>
        </arguments>
    </type>
    <type name="Nicepay\NicePayment\Logger\Logger">
        <arguments>
            <argument name="name" xsi:type="string">Logger</argument>
            <argument name="handlers" xsi:type="array">
                <item name="system" xsi:type="object">Nicepay\NicePayment\Logger\Handler</item>
            </argument>
        </arguments>
    </type>
</config>
